{
    "title": "HierarchyOrchestratorState",
    "type": "object",
    "required": [
        "current_phase",
        "parameters",
        "tasks",
        "grand_summary"
    ],
    "properties": {
        "current_phase": {
            "type": "string",
            "enum": [
                "Phase 1",
                "Phase 2",
                "Phase 3",
                "Phase 4"
            ]
        },
        "parameters": {
            "type": "object",
            "properties": {
                "parallelism": {
                    "type": "integer",
                    "default": 5
                },
                "max_rejections": {
                    "type": "integer",
                    "default": 3
                },
                "member_count": {
                    "type": "integer",
                    "default": 3
                },
                "checklist_path": {
                    "type": "string",
                    "default": "docs/hierarchy-checklist.md"
                }
            }
        },
        "tasks": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "task_id",
                    "description",
                    "checklist",
                    "status",
                    "rejection_count"
                ],
                "properties": {
                    "task_id": {
                        "type": "string",
                        "pattern": "^T[0-9]{3}$"
                    },
                    "status": {
                        "type": "string",
                        "enum": [
                            "TODO",
                            "IN_PROGRESS",
                            "IN_REVIEW",
                            "APPROVED",
                            "REJECTED",
                            "ERROR"
                        ]
                    },
                    "depends_on": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "grand_summary": {
            "type": [
                "string",
                "null"
            ]
        }
    }
}